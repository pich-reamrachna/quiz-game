{
	"name": "quiz-game",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''; lefthook install",
		"check": "svelte-kit sync && svelte-fast-check --incremental",
		"check:ci": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test:unit": "vitest",
		"test": "pnpm run test:unit -- --run",
		"test:coverage": "vitest run --coverage",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"migrate": "node --env-file=.env scripts/migrate.mjs",
		"spell": "cspell \"**/*.{js,ts,svelte,md,json}\" --no-progress",
		"spell:fix": "cspell \"**/*.{js,ts,svelte,md,json}\" --no-progress --words-only",
		"update-latest": "pnpm update --latest"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.3",
		"@eslint/js": "^10.0.1",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.55.0",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.1",
		"@types/node": "^25.5.0",
		"@vitest/browser-playwright": "^4.1.0",
		"@vitest/coverage-v8": "^4.1.0",
		"cspell": "^9.7.0",
		"eslint": "^10.0.3",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-no-commented-code": "^1.0.10",
		"eslint-plugin-svelte": "^3.15.2",
		"globals": "^17.4.0",
		"lefthook": "^2.1.4",
		"playwright": "^1.58.2",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.53.11",
		"svelte-check": "^4.4.5",
		"svelte-fast-check": "^0.4.5",
		"tailwindcss": "^4.2.1",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.57.0",
		"vite": "^7.3.1",
		"vitest": "^4.1.0",
		"vitest-browser-svelte": "^2.1.0"
	},
	"dependencies": {
		"@libsql/client": "^0.17.0"
	},
	"pnpm": {
		"overrides": {
			"cookie": "^0.7.0"
		}
	}
}
